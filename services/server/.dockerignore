# Ignore git directories in ql_build
ql_build/**/.git
ql_build/**/.gitignore

# Ignore build artifacts in ql_build
ql_build/**/build/
ql_build/**/bin/
ql_build/**/obj/
ql_build/**/*.o
ql_build/**/*.obj
ql_build/**/*.exe
ql_build/**/*.dll
ql_build/**/*.lib
ql_build/**/*.pdb

# Ignore Visual Studio files in ql_build
ql_build/**/*.vcxproj.user
ql_build/**/*.vcxproj.filters
ql_build/**/*.sln.docstates
ql_build/**/Debug/
ql_build/**/Release/
ql_build/**/x64/
ql_build/**/.vs/

# Ignore Python cache in ql_build
ql_build/**/__pycache__/
ql_build/**/*.pyc
ql_build/**/*.pyo

# Ignore temporary files in ql_build
ql_build/**/*~
ql_build/**/*.tmp
ql_build/**/*.temp

