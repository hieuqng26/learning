# Base image with QuantLib and OpenSourceRiskEngine pre-built
# This image should be built separately and pushed to a registry
FROM registry.access.redhat.com/ubi9/ubi-minimal AS base

# Set the work directory
WORKDIR /usr/src/app

# Install all build dependencies in a single layer
RUN echo "sslverify=false" >> /etc/dnf/dnf.conf && \
    microdnf update -y && \
    microdnf install -y \
      gcc \
      gcc-c++ \
      findutils \
      openssl-devel \
      bzip2-devel \
      libffi-devel \
      zlib-devel \
      wget \
      make \
      sqlite-devel \
      xz-devel \
      pam \
      tar \
      bzip2 \
      which \
      file \
      autoconf \
      automake \
      libtool \
      pkgconfig \
      m4 \
      pcre2-devel \
      cmake && \
    microdnf clean all

# Install Python 3.11.9 from source (needed for specific version compatibility)
RUN cd /tmp && \
    wget --no-check-certificate --max-redirect=0 https://www.python.org/ftp/python/3.11.9/Python-3.11.9.tgz && \
    tar xzf Python-3.11.9.tgz && \
    cd Python-3.11.9 && \
    ./configure --enable-optimizations --prefix=/usr/local && \
    make altinstall && \
    ln -sf /usr/local/bin/python3.11 /usr/local/bin/python3 && \
    ln -sf /usr/local/bin/pip3.11 /usr/local/bin/pip3 && \
    cd /tmp && \
    rm -rf Python-3.11.9*

# Upgrade pip and install build tools
RUN /usr/local/bin/python3 -m pip install --trusted-host pypi.org --trusted-host pypi.python.org --trusted-host files.pythonhosted.org --upgrade pip setuptools build

